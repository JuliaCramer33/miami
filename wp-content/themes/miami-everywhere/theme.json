{
  "$schema": "https://schemas.wp.org/wp/6.2/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "defaultDuotone": false,
      "custom": true,
      "customDuotone": false,
      "customGradient": true,
      "duotone": [],
      "gradients": [
        {
          "slug": "card-overlay",
          "gradient": "linear-gradient(64deg, rgba(0, 0, 0, 0.50) 29.32%, rgba(102, 102, 102, 0.00) 55.18%)",
          "name": "Card Overlay"
        },
        {
          "slug": "hero-overlay",
          "gradient": "linear-gradient(180deg, rgba(0, 0, 0, 0.00) 14.58%, rgba(0, 0, 0, 0.20) 100%)",
          "name": "Hero Overlay"
        }
      ],
      "link": true,
      "palette": [
        {
          "slug": "miami-red",
          "color": "#C41230",
          "name": "Miami Red"
        },
        {
          "slug": "white",
          "color": "#FFFFFF",
          "name": "White"
        },
        {
          "slug": "accent-red",
          "color": "#AD102A",
          "name": "Accent Red"
        },
        {
          "slug": "light-tan",
          "color": "#EDECE2",
          "name": "Light Tan"
        },
        {
          "slug": "medium-tan",
          "color": "#CCC9B8",
          "name": "Medium Tan"
        },
        {
          "slug": "dark-tan",
          "color": "#70685C",
          "name": "Dark Tan"
        },
        {
          "slug": "medium-gray",
          "color": "#666666",
          "name": "Medium Gray"
        },
        {
          "slug": "warm-white",
          "color": "#FAF9F7",
          "name": "Warm White"
        },
        {
          "slug": "black",
          "color": "#000000",
          "name": "Black"
        }
      ]
    },
    "custom": {},
    "layout": {
      "contentSize": "800px",
      "wideSize": "1000px"
    },
    "spacing": {
      "margin": true,
      "padding": true,
      "units": [
        "px",
        "em",
        "rem",
        "vh",
        "vw",
        "%"
      ]
    },
    "typography": {
      "customFontSize": true,
      "lineHeight": true,
      "dropCap": false,
      "fontSizes": [
        {
          "slug": "small",
          "size": "16px",
          "name": "Small"
        },
        {
          "slug": "medium",
          "size": "18px",
          "name": "Medium"
        },
        {
          "slug": "large",
          "size": "24px",
          "name": "Large"
        }
      ]
    },
    "blocks": {
      "core/button": {
        "color": {
          "palette": [
            {
              "slug": "miami-red",
              "color": "#C41230",
              "name": "Miami Red"
            },
            {
              "slug": "white",
              "color": "#FFFFFF",
              "name": "White"
            },
            {
              "slug": "accent-red",
              "color": "#AD102A",
              "name": "Accent Red"
            }
          ]
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--black)"
    },
    "elements": {
      "h1": {
        "color": {
          "text": "var(--wp--preset--color--miami-red)"
        }
      },
      "h2": {
        "color": {
          "text": "var(--wp--preset--color--miami-red)"
        }
      },
      "h3": {
        "color": {
          "text": "var(--wp--preset--color--dark-tan)"
        }
      },
      "h4": {
        "color": {
          "text": "var(--wp--preset--color--dark-tan)"
        }
      },
      "h5": {
        "color": {
          "text": "var(--wp--preset--color--black)"
        }
      },
      "h6": {
        "color": {
          "text": "var(--wp--preset--color--black)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--miami-red)"
        }
      }
    },
    "typography": {},
    "blocks": {}
  }
}